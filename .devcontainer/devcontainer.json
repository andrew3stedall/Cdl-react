{
  "name": "CDL React Codespace",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [5173, 8000],
  "portsAttributes": {
    "5173": {
      "label": "CDL React frontend",
      "onAutoForward": "openBrowser"
    },
    "8000": {
      "label": "CDL React API",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "python -m pip install --user uv && ~/.local/bin/uv sync && cd frontend && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
